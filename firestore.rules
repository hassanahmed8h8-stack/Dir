rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: properties
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - price: string (required)
    //   - location: string (required)
    //   - type: string (required)
    //   - area: string (required)
    //   - imageUrl: string (required)
    //   - status: string (required, 'متاح' or 'تم البيع')
    //   - bedrooms: number (optional)
    //   - bathrooms: number (optional)
    //   - features: list of strings (optional)
    //   - googleMapsLink: string (optional)
    //
    // ===============================================================
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == 'admin@dar.com' || request.auth.token.email == 'hassanahmed8h8@gmail.com');
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }
    
    function isValidProperty() {
      let data = request.resource.data;
      let requiredFields = ['title', 'description', 'price', 'location', 'type', 'area', 'imageUrl', 'status'];
      
      return hasRequiredFields(requiredFields) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 200 &&
             data.type is string && data.type.size() > 0 && data.type.size() < 50 &&
             data.area is string && data.area.size() > 0 && data.area.size() < 50 &&
             isValidUrl(data.imageUrl) &&
             (data.status == 'متاح' || data.status == 'تم البيع') &&
             (!('bedrooms' in data) || data.bedrooms is number) &&
             (!('bathrooms' in data) || data.bathrooms is number) &&
             (!('features' in data) || (data.features is list && data.features.size() <= 50)) &&
             (!('googleMapsLink' in data) || data.googleMapsLink == '' || isValidUrl(data.googleMapsLink));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /properties/{propertyId} {
      // Anyone can read properties
      allow read: if true;
      
      // Only authenticated users (admins) can create, update, or delete properties
      allow create: if isAdmin() && isValidProperty();
      allow update: if isAdmin() && isValidProperty();
      allow delete: if isAdmin();
    }
  }
}
